# Display name for the weather screen
LOCATION_NAME=Saint Paul, Minnesota

# Coordinates for weather forecast
LATITUDE=44.9537
LONGITUDE=-93.0900

# IANA timezone used for the clock, weather, and calendar display
TIMEZONE=America/Chicago

# Private or public ICS feed URL for your calendar
# Example: https://calendar.google.com/calendar/ical/.../basic.ics
CALENDAR_ICS_URL=

# Optional port for the local web server
PORT=3000
